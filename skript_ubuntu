#!/bin/bash
set -euo pipefail

# =========================
# Konfiguration
# =========================
DB_USER="admin"
DB_PASSWORD="Login.01"
DB_NAME="kunden_db"

APP_DIR="$HOME/Kunden_App"
PORT=3000
PG_VERSION="17"

echo ">>> System wird aktualisiert und Werkzeuge werden installiert..."
sudo apt update
# pgloader wird nur installiert, aber im Script nicht ausgeführt
sudo apt install -y curl build-essential git postgresql postgresql-contrib pgloader

echo ">>> Prüfe PostgreSQL Installation..."

if ! sudo pg_lsclusters | grep -q "main"; then
  echo ">>> Kein PostgreSQL-Cluster gefunden – wird erstellt..."
  sudo pg_createcluster "$PG_VERSION" main
fi

sudo systemctl start postgresql
sudo systemctl enable postgresql

# Rolle und leere Datenbank erstellen
if sudo -u postgres psql -tAc "SELECT 1 FROM pg_roles WHERE rolname = '$DB_USER'" | grep -q 1; then
  echo ">>> Rolle existiert bereits."
else
  echo ">>> Rolle wird erstellt..."
  sudo -u postgres psql -c "CREATE ROLE $DB_USER WITH LOGIN PASSWORD '$DB_PASSWORD';"
fi

if sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname = '$DB_NAME'" | grep -q 1; then
  echo ">>> Datenbank existiert bereits."
else
  echo ">>> Leere PostgreSQL-Zieldatenbank wird erstellt..."
  sudo -u postgres createdb -O "$DB_USER" "$DB_NAME"
fi

# Rechte für den späteren Import vorbereiten
echo ">>> Berechtigungen werden konfiguriert..."
sudo -u postgres psql -d "$DB_NAME" <<EOF
ALTER SCHEMA public OWNER TO $DB_USER;
GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO $DB_USER;
GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON TABLES TO $DB_USER;
EOF

echo ">>> Node.js Installation..."
if ! command -v node >/dev/null 2>&1; then
  curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -
  sudo apt install -y nodejs
fi

echo ">>> Anwendung wird eingerichtet..."
mkdir -p "$APP_DIR"
cd "$APP_DIR"

cat > package.json <<EOF
{
  "name": "kunden_app",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.11.5"
  }
}
EOF

npm install --silent

cat > index.js <<EOF
const express = require('express');
const { Pool } = require('pg');
const app = express();
const port = ${PORT};

const pool = new Pool({
  user: '${DB_USER}',
  host: 'localhost',
  database: '${DB_NAME}',
  password: '${DB_PASSWORD}',
  port: 5432,
});

app.get('/', async (req, res) => {
  try {
    // Die Anwendung erwartet die Tabelle 'kunden' nach dem manuellen pgloader-Lauf
    const result = await pool.query('SELECT * FROM kunden ORDER BY id ASC');
    const rows = result.rows;

    const html = \`
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kundendatenbank</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 40px; background-color: #f8f9fa; color: #333; }
        .container { max-width: 1200px; margin: auto; background: white; padding: 25px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 3px solid #007bff; padding-bottom: 10px; }
        h1 { margin: 0; color: #007bff; }
        .btn-refresh { background-color: #007bff; color: white; border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold; }
        .btn-refresh:hover { background-color: #0056b3; }
        table { border-collapse: collapse; width: 100%; margin-top: 10px; }
        th, td { border: 1px solid #dee2e6; padding: 12px; text-align: left; }
        th { background: #007bff; color: white; }
        tr:nth-child(even) { background-color: #f2f2f2; }
        tr:hover { background-color: #e9ecef; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Kundenliste</h1>
            <button class="btn-refresh" onclick="window.location.reload()">🔄 Aktualisieren</button>
        </div>
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Vorname</th>
                    <th>Firma</th>
                    <th>Adresse</th>
                    <th>Email</th>
                    <th>Telefon</th>
                </tr>
            </thead>
            <tbody>
                \${rows.map(k => \`
                <tr>
                    <td>\${k.id ?? ''}</td>
                    <td><strong>\${k.name ?? ''}</strong></td>
                    <td>\${k.vorname ?? ''}</td>
                    <td>\${k.firma ?? ''}</td>
                    <td>\${k.adresse ?? ''} \${k.hausnummer ?? ''}</td>
                    <td>\${k.email ?? ''}</td>
                    <td>\${k.telefonnummer ?? ''}</td>
                </tr>\`).join('')}
            </tbody>
        </table>
    </div>
</body>
</html>\`;
    res.send(html);
  } catch (err) {
    res.status(500).send('<h3>Datenbank bereit, aber Tabelle fehlt noch.</h3><p>Bitte führen Sie pgloader manuell aus, um die Tabelle \"kunden\" zu erstellen.</p><p>Fehler: ' + err.message + '</p>');
  }
});

app.listen(port, () => {
  console.log("SERVER GESTARTET: http://localhost:\${port}");
});
EOF

# Anwendung im Hintergrund starten
pkill -f "node index.js" || true
nohup node index.js > app.log 2>&1 &

sleep 2

echo "======================================="
echo "INSTALLATION ABGESCHLOSSEN (Bereit für Migration)"
echo "App-URL: http://localhost:${PORT}"
echo "---------------------------------------"
echo "Checkliste der Spalten im Tableau:"
echo "1. ID"
echo "2. Name"
echo "3. Vorname"
echo "4. Firma"
echo "5. Adresse (Strasse + Hausnummer)"
echo "6. Email"
echo "7. Telefon"
echo "======================================="
