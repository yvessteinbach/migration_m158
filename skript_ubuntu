#!/bin/bash
set -euo pipefail

# =========================
# Konfiguration
# =========================
DB_USER="admin"
DB_PASSWORD="Login.01"
DB_NAME="kunden_db"

# MariaDB / MySQL Quelle
MYSQL_USER="root"
MYSQL_PASSWORD="Login.01"
MYSQL_HOST="windows_ip"
MYSQL_DB="kunden_db"

APP_DIR="$HOME/Kunden_App"
PORT=3000
PG_VERSION="17"

echo ">>> System wird aktualisiert..."
sudo apt update
sudo apt install -y curl build-essential git postgresql postgresql-contrib pgloader

echo ">>> Prüfe PostgreSQL Installation..."

# Falls kein Cluster existiert -> erstellen
if ! sudo pg_lsclusters | grep -q "main"; then
  echo ">>> Kein PostgreSQL-Cluster gefunden – wird erstellt..."
  sudo pg_createcluster "$PG_VERSION" main
fi

echo ">>> PostgreSQL wird gestartet..."
sudo systemctl start postgresql
sudo systemctl enable postgresql

if ! sudo systemctl is-active --quiet postgresql; then
  echo "FEHLER: PostgreSQL konnte nicht gestartet werden."
  exit 1
fi

echo ">>> PostgreSQL läuft."

# Rolle erstellen falls nicht vorhanden
if sudo -u postgres psql -tAc "SELECT 1 FROM pg_roles WHERE rolname = '$DB_USER'" | grep -q 1; then
  echo ">>> Rolle existiert bereits."
else
  echo ">>> Rolle wird erstellt..."
  sudo -u postgres psql -c "CREATE ROLE $DB_USER WITH LOGIN PASSWORD '$DB_PASSWORD';"
fi

# Ziel-Datenbank erstellen falls nicht vorhanden
if sudo -u postgres psql -tAc "SELECT 1 FROM pg_database WHERE datname = '$DB_NAME'" | grep -q 1; then
  echo ">>> Datenbank existiert bereits."
else
  echo ">>> Leere PostgreSQL-Zieldatenbank wird erstellt..."
  sudo -u postgres createdb -O "$DB_USER" "$DB_NAME"
fi

echo ">>> Setze Eigentümerrechte auf Datenbank..."
sudo -u postgres psql -c "ALTER DATABASE $DB_NAME OWNER TO $DB_USER;"

echo ">>> Starte Migration von MariaDB nach PostgreSQL mit pgloader..."

PGLOADER_SOURCE="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}/${MYSQL_DB}"
PGLOADER_TARGET="postgresql://${DB_USER}:${DB_PASSWORD}@localhost/${DB_NAME}"

pgloader "$PGLOADER_SOURCE" "$PGLOADER_TARGET"

echo ">>> Migration abgeschlossen."

echo ">>> Rechte auf Schema und Objekte werden gesetzt..."
sudo -u postgres psql -d "$DB_NAME" <<EOF
ALTER SCHEMA public OWNER TO $DB_USER;
GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO $DB_USER;
GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO $DB_USER;
GRANT ALL PRIVILEGES ON ALL FUNCTIONS IN SCHEMA public TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON TABLES TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON SEQUENCES TO $DB_USER;
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON FUNCTIONS TO $DB_USER;
EOF

echo ">>> Node.js wird installiert falls notwendig..."
if ! command -v node >/dev/null 2>&1; then
  curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -
  sudo apt install -y nodejs
fi

echo ">>> Anwendung wird eingerichtet..."
mkdir -p "$APP_DIR"
cd "$APP_DIR"

cat > package.json <<EOF
{
  "name": "kunden_app",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.11.5"
  }
}
EOF

npm install --silent

cat > index.js <<EOF
const express = require('express');
const { Pool } = require('pg');

const app = express();
const port = ${PORT};

const pool = new Pool({
  user: '${DB_USER}',
  host: 'localhost',
  database: '${DB_NAME}',
  password: '${DB_PASSWORD}',
  port: 5432,
});

app.get('/', async (req, res) => {
  try {
    const result = await pool.query('SELECT * FROM kunden ORDER BY id ASC');
    const rows = result.rows;

    const html = \`
<html lang="de">
<head>
<meta charset="UTF-8">
<title>Kundendatenbank</title>
<style>
body { font-family: Arial; margin: 40px; }
table { border-collapse: collapse; width: 100%; }
th, td { border: 1px solid #ccc; padding: 10px; }
th { background: #f4f4f4; }
</style>
</head>
<body>
<h1>Kundenliste</h1>
<table>
<tr>
<th>ID</th><th>Name</th><th>Vorname</th><th>Firma</th><th>Adresse</th><th>Email</th><th>Telefon</th>
</tr>
\${rows.map(k => \`
<tr>
<td>\${k.id ?? ''}</td>
<td>\${k.name ?? ''}</td>
<td>\${k.vorname ?? ''}</td>
<td>\${k.firma ?? ''}</td>
<td>\${k.adresse ?? ''}\${k.hausnummer ? ' ' + k.hausnummer : ''}</td>
<td>\${k.email ?? ''}</td>
<td>\${k.telefonnummer ?? ''}</td>
</tr>\`).join('')}
</table>
</body>
</html>\`;

    res.send(html);
  } catch (err) {
    res.status(500).send('Datenbankfehler: ' + err.message);
  }
});

app.listen(port, () => {
  console.log("SERVER GESTARTET: http://localhost:${PORT}");
});
EOF

pkill -f "node index.js" || true
nohup node index.js > app.log 2>&1 &

sleep 2

if curl -s "http://localhost:${PORT}" > /dev/null; then
  echo "======================================="
  echo "ANWENDUNG LÄUFT:"
  echo "http://localhost:${PORT}"
  echo "======================================="
else
  echo "FEHLER: Anwendung startet nicht."
fi
