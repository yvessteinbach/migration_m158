#!/bin/bash

# Farben für die Ausgabe
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${GREEN}>>> Update System und installiere Abhängigkeiten...${NC}"
sudo apt update && sudo apt upgrade -y
sudo apt install -y curl build-essential git

# 1. PostgreSQL Installation
echo -e "${GREEN}>>> Installiere PostgreSQL...${NC}"
sudo apt install -y postgresql postgresql-contrib

# Datenbank und User einrichten
echo -e "${GREEN}>>> Konfiguriere Datenbank...${NC}"
sudo -u postgres psql -c "CREATE DATABASE kunden_db;"
sudo -u postgres psql -c "CREATE USER admin WITH PASSWORD 'passwort123';"
sudo -u postgres psql -c "GRANT ALL PRIVILEGES ON DATABASE kunden_db TO admin;"
sudo -u postgres psql -d kunden_db -c "CREATE TABLE IF NOT EXISTS kunden (id INT AUTO_INCREMENT PRIMARY KEY, name VARCHAR(255), vorname VARCHAR(255), firma VARCHAR(255), adresse VARCHAR(255), hausnummer INT, email VARCHAR(255), telefonnummer VARCHAR(20));"
sudo -u postgres psql -d kunden_db -c "INSERT INTO kunden (name, vorname, firma, adresse, hausnummer, email, telefonnummer) VALUES ('Mustermann', 'Max', 'Firma A', 'Musterstraße', 123, 'max@mariadb.win', '+41 76 123 45 67'), ('Musterfrau', 'Erika', 'Firma B', 'Musterstraße', 456, 'erika@mariadb.win', '+41 76 987 65 43');"

# 2. Node.js Installation (Version 20 LTS)
echo -e "${GREEN}>>> Installiere Node.js 20...${NC}"
curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -
sudo apt install -y nodejs

# 3. Web-Applikation erstellen
echo -e "${GREEN}>>> Erstelle Web-App-Verzeichnis...${NC}"
mkdir -p ~/Kunden_App
cd ~/Kunden_App

# package.json erstellen
cat <<EOF > package.json
{
  "name": "kunden_app",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.11.5"
  }
}
EOF

# Node-Pakete installieren
npm install

# index.js erstellen (Das Backend)
cat <<EOF > index.js
const express = require('express');
const { Pool } = require('pg');
const app = express();
const port = 3000;

const pool = new Pool({
  user: 'admin',
  host: 'localhost',
  database: 'kunden_db',
  password: 'Login.01',
  port: 5432,
});

app.get('/', async (req, res) => {
  try {
    const result = await pool.query('SELECT * FROM kunden');
    let html = '<h1>Kundendatenbank</h1><ul>';
    result.rows.forEach(kunde => {
      html += \`<li>\${kunde.name} - \${kunde.email}</li>\`;
    });
    html += '</ul>';
    res.send(html);
  } catch (err) {
    console.error(err);
    res.status(500).send('Datenbankfehler');
  }
});

app.listen(port, () => {
  console.log(\`Server läuft auf http://localhost:\${port}\`);
});
EOF

echo -e "${GREEN}>>> Setup abgeschlossen!${NC}"
echo "Starte die App mit: cd ~/mein_webprojekt && node index.js"
