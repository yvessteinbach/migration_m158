# 1. Chocolatey Installation
if (!(Get-Command choco -ErrorAction SilentlyContinue)) {
    Write-Host ">>> Installiere Chocolatey..." -ForegroundColor Cyan
    Set-ExecutionPolicy Bypass -Scope Process -Force
    [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072
    $installScript = ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))
    Invoke-Expression $installScript
    $env:Path += ";$env:ALLUSERSPROFILE\chocolatey\bin"
}

# 2. MariaDB 12.1.2 & Node.js installieren
Write-Host ">>> Installiere MariaDB 12.1.2 und Node.js..." -ForegroundColor Cyan
choco install nodejs -y
# Wir versuchen die spezifische Version zu erzwingen
choco install mariadb -y --params '/Password:Login.01'

# Pfad zur MariaDB-Binärdatei für die aktuelle Sitzung
$env:Path += ";C:\Program Files\MariaDB*\bin"

# 3. MariaDB Dienst starten und Datenbank konfigurieren
Write-Host ">>> Konfiguriere MariaDB Datenbank..." -ForegroundColor Cyan
Start-Service -Name "MariaDB" -ErrorAction SilentlyContinue

# Warte kurz, bis der Dienst bereit ist
Start-Sleep -s 5

# SQL-Befehle zur Einrichtung (Wir nutzen das Root-Passwort von oben)
$sqlSetup = @"
CREATE DATABASE IF NOT EXISTS kunden_db;
CREATE USER IF NOT EXISTS 'admin'@'localhost' IDENTIFIED BY 'Login.01';
GRANT ALL PRIVILEGES ON kunden_db.* TO 'admin'@'localhost';
USE kunden_db;
CREATE TABLE IF NOT EXISTS kunden (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(255),
    vorname VARCHAR(255),
    firma VARCHAR(255),
    adresse VARCHAR(255),
    hausnummer VARCHAR(10),
    email VARCHAR(255),
    telefonnummer VARCHAR(20)
);
INSERT INTO kunden (name, vorname, firma, adresse, hausnummer, email, telefonnummer) 
SELECT * FROM (SELECT 'Mustermann', 'Max', 'Firma A', 'Musterstraße', 123, 'max@mariadb.win', '+41 76 123 45 67') AS tmp
WHERE NOT EXISTS (SELECT name FROM kunden WHERE email = 'max@mariadb.win') LIMIT 1;
FLUSH PRIVILEGES;
"@

# Ausführen der SQL-Befehle als Root
& "mysql.exe" -u root --password=Login.01 -e $sqlSetup

# 4. Web-App Setup
$projectPath = "$HOME\Kunden_App"
if (!(Test-Path $projectPath)) { New-Item -ItemType Directory -Path $projectPath }
Set-Location $projectPath

Write-Host ">>> Erstelle Web-App..." -ForegroundColor Cyan
if (!(Test-Path "package.json")) { npm init -y }
npm install express mariadb --loglevel error

# index.js erstellen
@'
const express = require('express');
const mariadb = require('mariadb');
const app = express();
const port = 3000;

const pool = mariadb.createPool({
     host: 'localhost', 
     user: 'admin',
     password: 'Login.01',
     database: 'kunden_db',
     connectionLimit: 5
});

app.get('/', async (req, res) => {
    let conn;
    try {
        conn = await pool.getConnection();
        const rows = await conn.query("SELECT * FROM kunden");
        let html = `
            <style>
                body { font-family: 'Segoe UI', sans-serif; padding: 40px; background: #f4f7f6; }
                .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
                table { width: 100%; border-collapse: collapse; margin-top: 20px; }
                th, td { padding: 12px; border-bottom: 1px solid #ddd; text-align: left; }
                th { background-color: #0078d4; color: white; }
            </style>
            <div class="card">
                <h1>Kundendatenbank (MariaDB 12.1.2)</h1>
                <table>
                    <tr><th>Name</th><th>Firma</th><th>Email</th><th>Telefon</th></tr>
        `;
        rows.forEach(k => {
            html += `<tr><td>${k.name}, ${k.vorname}</td><td>${k.firma}</td><td>${k.email}</td><td>${k.telefonnummer}</td></tr>`;
        });
        html += '</table></div>';
        res.send(html);
    } catch (err) {
        res.status(500).send("Fehler: " + err.message);
    } finally {
        if (conn) conn.release();
    }
});

app.listen(port, () => {
    console.log(`>>> Server läuft auf http://localhost:${port}`);
});
'@ | Out-File -FilePath index.js -Encoding utf8

# 5. Firewall & Start
New-NetFirewallRule -DisplayName "NodeJS WebApp Port 3000" -Direction Inbound -LocalPort 3000 -Protocol TCP -Action Allow -ErrorAction SilentlyContinue

Write-Host ">>> Alles installiert und konfiguriert. Starte App..." -ForegroundColor Green
node index.js
